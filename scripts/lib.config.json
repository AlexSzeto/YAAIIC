{
  "libraries": [
    {
      "url": "https://esm.sh/preact@10.19.2",
      "path": "preact/preact.js",
      "injectAs": "importmap",
      "importMapKey": "preact"
    },
    {
      "url": "https://esm.sh/preact@10.19.2/hooks?external=preact",
      "path": "preact/hooks.js",
      "injectAs": "importmap",
      "importMapKey": "preact/hooks"
    },
    {
      "url": "https://esm.sh/preact@10.19.2/compat?external=preact",
      "path": "preact/compat.js",
      "injectAs": "importmap",
      "importMapKey": "preact/compat"
    },
    {
      "url": "https://esm.sh/@preact/signals@1.2.2?external=preact",
      "path": "preact/signals.js",
      "injectAs": "importmap",
      "importMapKey": "@preact/signals"
    },
    {
      "url": "https://esm.sh/htm@3.1.1/preact?external=preact",
      "path": "htm/preact.js",
      "injectAs": "importmap",
      "importMapKey": "htm/preact"
    },
    {
      "url": "https://esm.sh/goober@2.1.13",
      "path": "goober/goober.js",
      "injectAs": "importmap",
      "importMapKey": "goober"
    },
    {
      "url": "https://esm.sh/goober@2.1.13/prefixer",
      "path": "goober/prefixer.js",
      "injectAs": "importmap",
      "importMapKey": "goober/prefixer"
    },
    {
      "url": "https://cdn.jsdelivr.net/npm/@tarekraafat/autocomplete.js@10.2.7/dist/autoComplete.min.js",
      "path": "autocomplete/autoComplete.min.js",
      "injectAs": "script"
    },
    {
      "url": "https://unpkg.com/boxicons@latest/dist/boxicons.js",
      "path": "boxicons/boxicons.js",
      "injectAs": "script"
    },
    {
      "url": "https://unpkg.com/favloader",
      "path": "favloader/favloader.js",
      "injectAs": "script"
    }
  ],
  "fonts": [
    {
      "family": "Figtree",
      "specs": "ital,wght@0,300..900;1,300..900",
      "display": "swap"
    },
    {
      "family": "Material Symbols Outlined",
      "specs": "opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200",
      "display": "block"
    }
  ]
}
